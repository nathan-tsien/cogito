/target
**/*.rs.bk
Cargo.lock.bak

# Fixture crates under integration tests are standalone (non-workspace)
# packages — their `target/` and `Cargo.lock` are generated on demand by
# the tests that invoke `cargo` against them and must not be tracked.
crates/*/tests/fixtures/**/target/
crates/*/tests/fixtures/**/Cargo.lock

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# cogito runtime state
*.db
*.db-shm
*.db-wal
.cogito/

# Local debug / scratch artefacts (e.g. Claude Code session graphs)
debug/

# cogito chat session event logs (local only)
sessions/

# Local environment variables (secrets; use .env.example as template)
.env

# Git worktrees (superpowers:using-git-worktrees default location)
.worktrees/
