# cogito local test environment
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real credentials.

# ── Anthropic ────────────────────────────────────────────────────────────────
# Required when using --provider anthropic (or model names starting with claude-)
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI-compatible endpoint (vLLM / SGLang / SenseNova / Azure OpenAI) ───
# Base URL of the Chat Completions endpoint, e.g. http://localhost:8000/v1
OPENAI_BASE_URL=http://localhost:8000/v1

# API key for the OpenAI-compatible endpoint; leave empty for unauthenticated
# private deployments.
OPENAI_API_KEY=

# ── Default model for `make chat` / `make chat-anthropic` ───────────────────
# Override per-invocation with: make chat MODEL=claude-opus-4-7
MODEL=sensenova-6.7-flash-lite

# ── Session storage ──────────────────────────────────────────────────────────
# Directory where per-session JSONL event logs are written.
SESSION_ROOT=./sessions

# ── Logging ──────────────────────────────────────────────────────────────────
# Set to `debug` or `cogito=debug` for verbose harness tracing.
RUST_LOG=info
